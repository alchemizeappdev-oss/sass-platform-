{
  "name": "ai-workforce",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @ai-workforce/database generate",
    "db:migrate": "pnpm --filter @ai-workforce/database migrate:dev",
    "db:push": "pnpm --filter @ai-workforce/database push",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  }
}
